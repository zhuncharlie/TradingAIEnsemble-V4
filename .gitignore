# default naming — see adapters/rdagent_adapter.py header once it exists).
/git_ignore_folder/
/log/
/pickle_cache/
# ARIS skills (project-local symlink install) — machine-specific, points
# outside this repo to ~/aris_repo. Re-installable via
# `bash ~/aris_repo/tools/install_aris.sh .`, see CLAUDE.md's ARIS block.
.claude/skills/
.aris/
