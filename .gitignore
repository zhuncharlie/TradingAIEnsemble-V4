__pycache__/
*.py[cod]
*.egg-info/
.env
*.env
adapters/vendor/
*.png
*.csv
# Adapter capability-recovery audit deliverable — a paper/report artifact
# at repo root, not scratch output.
!adapter_capability_recovery.csv
# New-adapter integration deliverable — same category as the above.
!new_adapter_integration.csv
# Q4 stepwise support-status deliverable — same category as the above.
!q4_stepwise_support.csv
# Comparison-layer chart outputs are paper deliverables, not scratch output.
!plots/*.png
!plots/*.html
# ICAIF experiment-suite outputs (figures/tables) are paper deliverables too.
!reports/icaif_experiments/*.png
!reports/icaif_experiments/*.csv
# Real observation data (adapter results) is a paper deliverable too — the
# whole tree, not just the top level, so override *.png/*.csv for it.
!results/**/*.png
!results/**/*.csv
# RD-Agent's own runtime workspace/cache when run from repo root (its own
# default naming — see adapters/rdagent_adapter.py header once it exists).
/git_ignore_folder/
/log/
/pickle_cache/
# ARIS skills (project-local symlink install) — machine-specific, points
# outside this repo to ~/aris_repo. Re-installable via
# `bash ~/aris_repo/tools/install_aris.sh .`, see CLAUDE.md's ARIS block.
.claude/skills/
.aris/
